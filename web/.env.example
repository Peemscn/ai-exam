# Claude API — ปกติ user ใส่ key เองในช่อง input (AI Q&A) / หรือ admin ตั้งที่นี่ก็ได้
ANTHROPIC_API_KEY=

# Turso (libSQL) — สร้าง DB ที่ app.turso.tech (เลือก region Singapore) แล้ว copy มา
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Apify (scrape ร้าน — primary) · ฟรี $5/เดือน · https://console.apify.com/account/integrations
APIFY_TOKEN=

# ปุ่ม re-scrape (/api/scrape → trigger GitHub Action — fallback ถ้า Apify token หมด)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
